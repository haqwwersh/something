#include <stdio.h>
#include <stdlib.h>

int main(int argc, char* argv[]) {
    if (argc != 3) {
        fprintf(stderr, "Error!: %s <num> <pos>\n", argv[0]);
        return 1;
    }

    int num = atoi(argv[1]);
    int pos = atoi(argv[2]);

    int mask = 1 << pos;

    int result = num ^ mask;

    printf("%d\n", result);

    return 0;
}
