#include <stdio.h>
#include <stdlib.h>

int main(int argc, char* argv[]) {
    if (argc != 4) {

        printf("Error");
        return 1;
    }

    int red = atoi(argv[1]);
    int green = atoi(argv[2]);
    int blue = atoi(argv[3]);

    unsigned int color = (red << 16) | (green << 8) | blue;

    printf("%u\n", color);

    return 0;
}
